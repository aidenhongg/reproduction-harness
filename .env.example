# ───────────────────────────────────────────────────────────────
# Paper-Reproduction Factory — shared credentials (the root .env)
# ───────────────────────────────────────────────────────────────
# Every paper project (papers/<paper>/) reads THIS file via ../../.env.
# There is no per-paper .env.
#
# SETUP:
#   1. Copy this file to ".env" in this same (root) directory.
#   2. Paste your real OpenRouter key below.
#   ".env" is gitignored; this ".env.example" is the committed template.
#
# Get a key at:  https://openrouter.ai/keys      (format: sk-or-v1-...)

OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# Optional — OpenAI-compatible endpoint (leave as-is unless told otherwise):
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
